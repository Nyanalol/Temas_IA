# ──────────────────────────────────────────────────────────────────────────────
# Copia este fichero a .env y rellena los valores que necesites.
# El .env NUNCA debe subirse a git (ya está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
# Proveedor activo. Opciones: ollama | openai | anthropic | groq
LLM_PROVIDER=ollama

# Modelo concreto del proveedor elegido.
# ollama    → llama3, mistral, phi3, gemma2…
# openai    → gpt-4o, gpt-4o-mini, gpt-3.5-turbo…
# anthropic → claude-3-5-sonnet-20241022, claude-3-haiku…
# groq      → llama3-8b-8192, mixtral-8x7b-32768…
LLM_MODEL=llama3

# Temperatura: 0 = determinista, 1 = más creativo.
LLM_TEMPERATURE=0

# ── Embeddings ────────────────────────────────────────────────────────────────
# Proveedor activo. Opciones: ollama | openai
EMBEDDING_PROVIDER=ollama

# ollama  → nomic-embed-text, mxbai-embed-large…
# openai  → text-embedding-3-small, text-embedding-3-large…
EMBEDDING_MODEL=nomic-embed-text

# ── API Keys ──────────────────────────────────────────────────────────────────
# Solo rellena la del proveedor que vayas a usar.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── iCloud Calendar (events/) ─────────────────────────────────────────────────
# App password de Apple (no tu contraseña normal).
# Créala en https://appleid.apple.com → Seguridad → Contraseñas de app
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=
ICLOUD_CALDAV_URL=https://caldav.icloud.com
ICLOUD_DEFAULT_CALENDAR=

# ── API REST (events/api.py) ───────────────────────────────────────────────────
# Clave secreta que enviará el iPhone en la cabecera X-API-Key.
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
